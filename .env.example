# Copy to .env and fill in values

# Enables the demo banner in the UI
VITE_DEMO=true

# Port for the Express server (default: 3001)
PORT=3002

# REQUIRED for POST /api/reset-demo. The endpoint fails closed: if this is
# unset or the request's X-Reset-Secret header doesn't match, the call
# returns 403. Generate with: openssl rand -base64 24
RESET_SECRET=

# Frontend origin allowed to call the API in production. Required in prod —
# if unset, all cross-origin requests are blocked. In development CORS is
# permissive.
# ALLOWED_ORIGIN=https://inspectr.plainspokenfoundrynine.com

# Set to "production" to enforce CORS and other production-only behavior.
# NODE_ENV=production
